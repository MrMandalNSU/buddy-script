generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum AccountStatus {
  ACTIVE
  DISABLED

  @@map("account_status")
}

enum PostVisibility {
  PUBLIC
  PRIVATE

  @@map("post_visibility")
}

enum ReactionType {
  LIKE
  LOVE
  CARE
  HAHA
  WOW
  SAD
  ANGRY

  @@map("reaction_type")
}

model User {
  id              String           @id @db.Uuid
  firstName       String           @map("first_name") @db.VarChar(80)
  lastName        String           @map("last_name") @db.VarChar(80)
  email           String           @db.VarChar(320)
  emailNormalized String           @unique(map: "users_email_normalized_key") @map("email_normalized") @db.VarChar(320)
  passwordHash    String           @map("password_hash") @db.VarChar(255)
  avatarUrl       String?          @map("avatar_url") @db.VarChar(2048)
  status          AccountStatus    @default(ACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  posts           Post[]
  comments        Comment[]
  postLikes       PostLike[]
  commentLikes    CommentLike[]
  refreshSessions RefreshSession[]

  @@index([status], map: "users_status_idx")
  @@map("users")
}

model RefreshSession {
  id               String           @id @db.Uuid
  userId           String           @map("user_id") @db.Uuid
  familyId         String           @map("family_id") @db.Uuid
  tokenHash        String           @unique(map: "refresh_sessions_token_hash_key") @map("token_hash") @db.Char(64)
  expiresAt        DateTime         @map("expires_at") @db.Timestamptz(3)
  persistent       Boolean          @default(true)
  revokedAt        DateTime?        @map("revoked_at") @db.Timestamptz(3)
  lastUsedAt       DateTime?        @map("last_used_at") @db.Timestamptz(3)
  replacedById     String?          @unique(map: "refresh_sessions_replaced_by_id_key") @map("replaced_by_id") @db.Uuid
  ipHash           String?          @map("ip_hash") @db.Char(64)
  userAgentHash    String?          @map("user_agent_hash") @db.Char(64)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy       RefreshSession?  @relation("SessionRotation", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces         RefreshSession?  @relation("SessionRotation")

  @@index([userId, expiresAt], map: "refresh_sessions_user_expiry_idx")
  @@index([familyId], map: "refresh_sessions_family_idx")
  @@map("refresh_sessions")
}

model Post {
  id                String         @id @db.Uuid
  authorId          String         @map("author_id") @db.Uuid
  body              String?        @db.VarChar(5000)
  visibility        PostVisibility @default(PUBLIC)
  imagePublicId     String?        @map("image_public_id") @db.VarChar(255)
  imageSecureUrl    String?        @map("image_secure_url") @db.VarChar(2048)
  imageVersion      Int?           @map("image_version")
  imageWidth        Int?           @map("image_width")
  imageHeight       Int?           @map("image_height")
  imageBytes        Int?           @map("image_bytes")
  imageFormat       String?        @map("image_format") @db.VarChar(20)
  likeCount         Int            @default(0) @map("like_count")
  commentCount      Int            @default(0) @map("comment_count")
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  author            User           @relation(fields: [authorId], references: [id], onDelete: Restrict)
  comments          Comment[]
  likes             PostLike[]

  @@index([authorId, createdAt(sort: Desc), id(sort: Desc)], map: "posts_author_created_id_idx")
  @@map("posts")
}

model Comment {
  id          String        @id @db.Uuid
  postId      String        @map("post_id") @db.Uuid
  authorId    String        @map("author_id") @db.Uuid
  parentId    String?       @map("parent_id") @db.Uuid
  depth       Int           @default(0) @db.SmallInt
  body        String        @db.VarChar(2000)
  likeCount   Int           @default(0) @map("like_count")
  replyCount  Int           @default(0) @map("reply_count")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  post        Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author      User          @relation(fields: [authorId], references: [id], onDelete: Restrict)
  parent      Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]     @relation("CommentReplies")
  likes       CommentLike[]

  @@index([postId, parentId, createdAt, id], map: "comments_post_parent_created_id_idx")
  @@index([parentId, createdAt, id], map: "comments_parent_created_id_idx")
  @@map("comments")
}

model PostLike {
  id           String       @id @db.Uuid
  postId       String       @map("post_id") @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  reactionType ReactionType @default(LIKE) @map("reaction_type")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  post         Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], map: "post_likes_post_user_key")
  @@index([postId, createdAt, id], map: "post_likes_post_created_id_idx")
  @@index([postId, updatedAt(sort: Desc), id(sort: Desc)], map: "post_likes_post_updated_id_idx")
  @@index([userId], map: "post_likes_user_idx")
  @@map("post_likes")
}

model CommentLike {
  id           String       @id @db.Uuid
  commentId    String       @map("comment_id") @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  reactionType ReactionType @default(LIKE) @map("reaction_type")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  comment      Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId], map: "comment_likes_comment_user_key")
  @@index([commentId, createdAt, id], map: "comment_likes_comment_created_id_idx")
  @@index([commentId, updatedAt(sort: Desc), id(sort: Desc)], map: "comment_likes_comment_updated_id_idx")
  @@index([userId], map: "comment_likes_user_idx")
  @@map("comment_likes")
}
