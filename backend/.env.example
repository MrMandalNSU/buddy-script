# Server Configuration
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
TRUST_PROXY=false
ALLOWED_ORIGINS=http://localhost:3000
SHUTDOWN_TIMEOUT_MS=10000

# Authentication
JWT_ACCESS_SECRET='REPLACE_WITH_ACCESS_SECRET_AT_LEAST_32_BYTES'
JWT_REFRESH_SECRET='REPLACE_WITH_REFRESH_SECRET_AT_LEAST_32_BYTES'
JWT_ISSUER=buddyscript-api
JWT_AUDIENCE=buddyscript-web
JWT_KEY_ID=primary-2026
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_TOKEN_TTL_SECONDS=2592000

# Defaults to true in production and false otherwise
COOKIE_SECURE=false
CURSOR_SIGNING_SECRET='REPLACE_WITH_CURSOR_SECRET_AT_LEAST_32_BYTES'

# DB
DATABASE_URL='POOLED_NEON_URL'
DIRECT_URL='DIRECT_NEON_URL'
DATABASE_URL_DEV='DB_DEV_URL'

# Cloudinary
CLOUDINARY_CLOUD_NAME='Name'
CLOUDINARY_API_KEY='Key'
CLOUDINARY_API_SECRET='Secret'
CLOUDINARY_POST_FOLDER=buddyscript
CLOUDINARY_MAX_IMAGE_BYTES=5000000

# Local single-process cache
CACHE_ENABLED=true
CACHE_PUBLIC_FEED_TTL_SECONDS=5
CACHE_MAX_KEYS=1000
